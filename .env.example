# ============================================================
# Apple 9 — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase — https://supabase.com
# Create a project, then find these in Project Settings > API
# ------------------------------------------------------------

# Pooler connection string (Transaction mode) — used at runtime
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used only for Prisma migrations (not pooled)
# Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Public project URL (Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"

# Public anon key (Project Settings > API > anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — NEVER expose on the client side (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ------------------------------------------------------------
# NextAuth.js v5 — https://authjs.dev
# ------------------------------------------------------------

# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of your app (no trailing slash)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# Stripe — https://stripe.com
# Create an account, then find keys in Developers > API keys
# For development, use test mode keys (prefixed sk_test_ / pk_test_)
# ------------------------------------------------------------

# Secret key — server-side only
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret — get from Stripe Dashboard > Webhooks
# Local dev: use Stripe CLI  →  stripe listen --forward-to localhost:3000/api/stripe/webhook
# Production: create endpoint at https://yourdomain.com/api/stripe/webhook
#   Events to enable: checkout.session.completed, checkout.session.expired
STRIPE_WEBHOOK_SECRET="whsec_..."

# Publishable key — safe to expose on the client side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ------------------------------------------------------------
# Anthropic — https://console.anthropic.com
# ------------------------------------------------------------

ANTHROPIC_API_KEY="sk-ant-..."

# ------------------------------------------------------------
# Resend — https://resend.com
# Create an account, add and verify your sending domain,
# then create an API key in Settings > API Keys
# ------------------------------------------------------------

RESEND_API_KEY="re_..."

# The verified "from" address for transactional emails
RESEND_FROM_EMAIL="Apple 9 <noreply@yourdomain.com>"

# ------------------------------------------------------------
# Kiwi.com Affiliate (optional — for flight booking widget)
# Register at https://partners.kiwi.com to get an affiliate ID
# If omitted, the flight enquiry form is used as fallback
# ------------------------------------------------------------

NEXT_PUBLIC_KIWI_AFFILIATE_ID=""

# ------------------------------------------------------------
# App
# ------------------------------------------------------------

# Public base URL (same as NEXTAUTH_URL — used for absolute links in emails)
NEXT_PUBLIC_URL="http://localhost:3000"
